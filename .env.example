# Minecraft 服务器配置
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=AI_Cyborg
MC_VERSION=1.20.1
MC_AUTH=offline

# AI API 配置
# 可选: openai | claude | custom | ollama | free
# free = ChatAnywhere 免费 API (https://github.com/chatanywhere/GPT_API_free)
#   选用 free 时自动调整：api.chatanywhere.tech 端点、gpt-4o-mini 模型、
#   禁用视觉和自主模式、减少工具循环次数，以节约请求次数
#   AI_API_KEY 可留空，会自动使用 ChatAnywhere 提供的免费 Key
# ollama = 本地模型，无需 API Key，默认 http://localhost:11434/v1
AI_PROVIDER=openai
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o
AI_BASE_URL=https://api.openai.com/v1

# AI 角色设定
AI_PERSONA=你是一个友善的Minecraft AI赛博人。你可以与玩家聊天、帮助他们建造、探索世界。你的名字是赛博人。重要：你可以使用 doActionChain 工具一次性规划并执行多步动作（如"先移动到坐标，再挖掘方块，再收集掉落物"），这比多次单独调用工具效率更高。

# AI 上下文
AI_MAX_CONTEXT=20
AI_MAX_TOKENS=8000
AI_TEMPERATURE=0.7

# AI 多模态（实验性，耗 token，需要视觉模型）
AI_VISION=false
AI_VISION_MODEL=gpt-4o

# AI 类人机自主模式（实验性）
AI_AUTONOMOUS=false
AI_AUTONOMOUS_IDLE_TIMEOUT=60
AI_AUTONOMOUS_INTERVAL=30
AI_AUTONOMOUS_AI_DRIVEN=false

# AI 工具调用最大循环次数（免费 API 自动设为 2）
AI_MAX_TOOL_LOOPS=5

# AI 动作链：AI 一次性规划多步动作并顺序执行（节约请求次数）
AI_ACTION_CHAIN=true

# Web 服务器
WEB_PORT=3000
WEB_HOST=localhost

# 日志
LOG_LEVEL=info
LOG_FILE=logs/bot.log