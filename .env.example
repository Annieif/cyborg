# Minecraft 服务器配置
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=AI_Cyborg
MC_VERSION=1.20.1
MC_AUTH=offline

# AI API 配置
AI_PROVIDER=openai
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o
AI_BASE_URL=https://api.openai.com/v1

# AI 角色设定
AI_PERSONA=你是一个友善的Minecraft AI赛博人。你可以与玩家聊天、帮助他们建造、探索世界。你的名字是赛博人。

# AI 上下文
AI_MAX_CONTEXT=20
AI_MAX_TOKENS=8000
AI_TEMPERATURE=0.7

# AI 多模态（实验性，耗 token，需要视觉模型）
AI_VISION=false
AI_VISION_MODEL=gpt-4o

# AI 类人机自主模式（实验性）
AI_AUTONOMOUS=false
AI_AUTONOMOUS_IDLE_TIMEOUT=60
AI_AUTONOMOUS_INTERVAL=30

# Web 服务器
WEB_PORT=3000
WEB_HOST=localhost

# 日志
LOG_LEVEL=info
LOG_FILE=logs/bot.log